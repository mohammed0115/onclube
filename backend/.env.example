# Copy to .env and adjust. Without DATABASE_URL the project falls back to SQLite.
#
# SECURITY: settings are fail-closed. In production (DEBUG=False) the app REFUSES
# to start unless SECRET_KEY is a strong non-default value and ALLOWED_HOSTS is
# set to explicit hostnames (not empty, not "*"). See config/security.py.

# ── Core (REQUIRED in production) ─────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
# Defaults to False. Set to True ONLY for local development.
DEBUG=True
# Comma-separated explicit hostnames in production, e.g. api.oneclub.app,oneclub.app
# May be left blank ONLY when DEBUG=True (falls back to localhost).
ALLOWED_HOSTS=

# ── Uploads ───────────────────────────────────────────────────────────────────
# Max payment-receipt upload size in bytes (default 5 MiB).
RECEIPT_MAX_UPLOAD_BYTES=5242880

# ── Placement assessment (OpenAI optional) ────────────────────────────────────
# Leave OPENAI_API_KEY blank to use the deterministic heuristic (no OpenAI calls).
# When set, OpenAI is primary and the heuristic remains the automatic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# ── Database (PostgreSQL in production) ───────────────────────────────────────
# Leave unset for local SQLite.
# DATABASE_URL=postgres://oneclub:password@localhost:5432/oneclub

# ── Production HTTPS notes ────────────────────────────────────────────────────
# When DEBUG=False the app enables HTTPS redirect, secure cookies, and HSTS, and
# trusts the X-Forwarded-Proto header from a reverse proxy. Terminate TLS at the
# proxy and forward X-Forwarded-Proto=https.

# ── Payment provider — configurable bank-transfer details (no hardcoded bank) ──
# Defaults shown; override per environment. Default provider: Bank of Khartoum / Bankak.
PAYMENT_BANK_NAME=Bank of Khartoum
PAYMENT_ACCOUNT_NAME=OneClub Education
PAYMENT_ACCOUNT_NUMBER=
PAYMENT_IBAN=
PAYMENT_TRANSFER_METHOD=Bankak
# PAYMENT_INSTRUCTIONS_TEXT=Open your Bankak app, transfer the exact amount …
