# ─────────────────────────────────────────────────────────────────────────────
# OneClup — production environment
# Copy to the project root as `.env.production`, fill in the values, keep it OUT
# of git. All compose commands below pass `--env-file .env.production` so this one
# file drives BOTH build-arg interpolation AND the container runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django core ──────────────────────────────────────────────────────────────
DEBUG=False
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_to_a_long_random_secret
# Nginx forwards Host: oneclup.com; localhost/127.0.0.1 let the container healthcheck pass.
ALLOWED_HOSTS=oneclup.com,www.oneclup.com,localhost,127.0.0.1
# Full https origins (scheme required by Django 4+).
CSRF_TRUSTED_ORIGINS=https://oneclup.com,https://www.oneclup.com
# Public base URL used to build password-reset / invite links in emails.
FRONTEND_URL=https://oneclup.com

# ── Database ─────────────────────────────────────────────────────────────────
# Bundled Postgres (compose --profile db): USE_EXTERNAL_DB=false and point
# DATABASE_URL / POSTGRES_HOST at the "postgres" service.
USE_EXTERNAL_DB=false
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=oneclup
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=oneclup
DATABASE_URL=postgres://oneclup:CHANGE_ME_strong_db_password@postgres:5432/oneclup
#
# External managed DB instead? Then:
#   USE_EXTERNAL_DB=true
#   DATABASE_URL=postgres://user:pass@your-db-host:5432/dbname
#   (leave POSTGRES_HOST empty and do NOT use --profile db)

# ── Cache / broker (optional; compose --profile cache) ───────────────────────
# REDIS_URL=redis://redis:6379/0

# ── Static / media (Nginx serves these from the bind-mounted dirs) ───────────
STATIC_URL=static/
STATIC_ROOT=/app/staticfiles
MEDIA_URL=media/
MEDIA_ROOT=/app/media

# ── Live video (Agora) ───────────────────────────────────────────────────────
PROVIDER_MODE=production
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate   # SECRET — backend only
AGORA_TOKEN_TTL_SECONDS=3600
# Build-time (baked into the SPA). App ID is public; MUST equal AGORA_APP_ID.
VITE_PROVIDER_MODE=production
VITE_AGORA_APP_ID=your_agora_app_id

# ── AI (optional; heuristic fallback if unset) ───────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email (optional; console backend if unset) ───────────────────────────────
NOTIFICATION_EMAILS_ENABLED=false
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=OneClup <no-reply@oneclup.com>

# ── Error monitoring (optional) ──────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ── Payments (bank transfer) ─────────────────────────────────────────────────
PAYMENT_ACCOUNT_NUMBER=
PAYMENT_IBAN=
PAYMENT_CURRENCY=SDG

# ── API rate limits (override the safe defaults if needed) ───────────────────
# THROTTLE_ANON=120/min
# THROTTLE_USER=480/min
# THROTTLE_AUTH=30/min

# ── Gunicorn tuning (optional) ───────────────────────────────────────────────
# GUNICORN_WORKERS=3
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=60
# GUNICORN_LOG_LEVEL=info
